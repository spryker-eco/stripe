{
    "name": "spryker-eco/stripe",
    "description": "Spryker Stripe integration",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "stripe/stripe-php": "^v13.0.0",
        "spryker-shop/checkout-page":"^3.36.0",
        "spryker/acl-merchant-portal-extension": "^1.0.0",
        "spryker/checkout-extension": "^1.5.0",
        "spryker/installer-extension": "^1.0.0",
        "spryker/kernel": "^3.81.0",
        "spryker/log": "^3.0.0",
        "spryker/merchant-app": "^1.4.0",
        "spryker/merchant-user": "^1.0.0",
        "spryker/oms": "^11.50.0",
        "spryker/oms-extension": "^1.6.0",
        "spryker/payment": "^5.28.0",
        "spryker/payment-app": "^2.3.0",
        "spryker/payment-extension": "^1.1.0",
        "spryker/propel-orm": "^1.21.0",
        "spryker/refund": "^5.0.0",
        "spryker/router": "^1.25.2",
        "spryker/sales": "^11.78.0",
        "spryker/sales-payment": "^1.0.0",
        "spryker/sales-payment-detail": "^1.5.0",
        "spryker/step-engine": "^3.7.0",
        "spryker/symfony": "^3.19.0",
        "spryker/transfer": "^3.27.0",
        "spryker/zed-request": "^3.26.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "spryker/code-sniffer": "*",
        "spryker/testify": "*"
    },
    "autoload": {
        "psr-4": {
            "SprykerEco\\": "src/SprykerEco/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SprykerEcoTest\\": "tests/SprykerEcoTest/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s src/ tests/",
        "cs-fix": "phpcbf -p src/ tests/",
        "phpstan": "vendor/bin/phpstan analyse"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
