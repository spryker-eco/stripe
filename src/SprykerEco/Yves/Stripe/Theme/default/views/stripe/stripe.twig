{% extends template('page-layout-checkout', 'CheckoutPage') %}

{% define data = {
    form: _view.paymentForm,
    stripePublishableKey: _view.stripePublishableKey | default(''),
    stripeClientSecret: _view.stripeClientSecret | default(''),
} %}

<div id="stripe-payment-form-wrapper">
    {{ form_row(data.form.stripe.transactionId, { attr: { id: 'stripe-transaction-id' } }) }}

    <div id="stripe-payment-element">
        {# Stripe Elements will mount here #}
    </div>

    <div id="stripe-payment-message" class="hidden" role="alert"></div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script src="https://js.stripe.com/v3/" async></script>
    <script>
        (function () {
            var publishableKey = '{{ data.stripePublishableKey | e('js') }}';
            var clientSecret = '{{ data.stripeClientSecret | e('js') }}';

            if (!publishableKey || !clientSecret) {
                console.warn('[Stripe] publishableKey or clientSecret missing — payment form will not initialize.');
                return;
            }

            var stripe = Stripe(publishableKey);
            var elements = stripe.elements({ clientSecret: clientSecret });
            var paymentElement = elements.create('payment');
            paymentElement.mount('#stripe-payment-element');

            var checkoutForm = document.querySelector('[name="checkoutForm"]') || document.querySelector('form');
            var transactionIdInput = document.getElementById('stripe-transaction-id');
            var messageContainer = document.getElementById('stripe-payment-message');

            if (!checkoutForm || !transactionIdInput) {
                console.warn('[Stripe] Could not find checkout form or transactionId input.');
                return;
            }

            checkoutForm.addEventListener('submit', function (event) {
                // Only intercept when stripe payment is selected
                if (!transactionIdInput.closest('[data-payment-provider]') && !transactionIdInput.value) {
                    event.preventDefault();

                    stripe.confirmPayment({
                        elements: elements,
                        redirect: 'if_required',
                    }).then(function (result) {
                        if (result.error) {
                            messageContainer.textContent = result.error.message;
                            messageContainer.classList.remove('hidden');
                            return;
                        }

                        if (result.paymentIntent) {
                            transactionIdInput.value = result.paymentIntent.id;
                            checkoutForm.submit();
                        }
                    });
                }
            });
        })();
    </script>
{% endblock %}
