{% extends template('page-layout-checkout', 'CheckoutPage') %}

{% define data = {
    orderReference: orderReference,
    idSalesOrder: idSalesOrder | default(null),
    stripePublishableKey: stripePublishableKey | default(''),
    stripeClientSecret: stripeClientSecret | default(''),
    checkoutSuccessUrl: checkoutSuccessUrl,
    paymentPageUrl: paymentPageUrl,
    orderDetailsUrl: orderDetailsUrl | default('#'),
} %}

{% block headTitle %}{{ 'stripe.payment.page.title' | trans }}{% endblock %}

{% block breadcrumbs %}{% endblock %}

{% block title %}
    <h1 class="title--h3">{{ 'stripe.payment.heading' | trans }}</h1>
{% endblock %}

{% block content %}
    <p>
        {{ 'stripe.payment.order.reference.text' | trans }} <strong><a href="{{ data.orderDetailsUrl }}" target="_blank">{{ data.orderReference }}</a></strong>.
    </p>
    <stripe-payment
        class="stripe-payment"
        style="display: block; max-width: 800px; margin: 40px auto; padding: 0 20px;"
        data-publishable-key="{{ data.stripePublishableKey | e('html_attr') }}"
        data-client-secret="{{ data.stripeClientSecret | e('html_attr') }}"
        data-checkout-success-url="{{ data.checkoutSuccessUrl | e('html_attr') }}"
        data-payment-page-url="{{ data.paymentPageUrl | e('html_attr') }}"
        data-error-failed="{{ 'stripe.payment.error.failed_redirect' | trans | e('html_attr') }}"
    >
        <div class="js-stripe-payment__payment-element"></div>
        <div class="js-stripe-payment__message" style="display:none; color: #df1b41; margin-top: 12px;"></div>

        <button class="js-stripe-payment__submit button" style="margin-top: 20px; width: 100%; padding: 12px;">
            {{ 'stripe.payment.button.pay' | trans }}
        </button>
    </stripe-payment>
{% endblock %}
